# ========== Facebook Developer ==========
# Lấy từ: https://developers.facebook.com/apps/ → chọn app → Cài đặt → Cơ bản

# App ID — bắt buộc cho đăng nhập Facebook (được dùng trên trình duyệt, có thể public)
VITE_FB_APP_ID=your_app_id_here

# App Secret (key) — KHÔNG thêm vào FE. Chỉ dùng ở Backend nếu bạn có (đổi token dài hạn).
# Nếu chỉ chạy FE: bỏ qua, không cần.
