# ========== Backend API ==========
# URL backend (không có /api ở cuối; FE sẽ gọi {VITE_API_URL}/api/...)
VITE_API_URL=http://localhost:8081

# ========== Facebook Login ==========
# App ID từ Facebook Developer Console - bắt buộc cho nút đăng nhập Facebook
VITE_FB_APP_ID=your_facebook_app_id

# ========== Ngrok (tùy chọn) ==========
# Chỉ cần khi chạy npm run ngrok hoặc npm run dev:all
# Lấy token: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken
